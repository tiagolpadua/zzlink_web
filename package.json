{
  "name": "zzlink_web",
  "version": "1.0.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc --build && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src index.html",
    "format:check": "prettier --check src index.html",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiagolpadua/zzlink_web.git"
  },
  "keywords": [
    "whatsapp",
    "link-generator",
    "wa.me",
    "qrcode",
    "alpine",
    "vite"
  ],
  "author": "Tiago Lage Payne de Pádua",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tiagolpadua/zzlink_web/issues"
  },
  "homepage": "https://github.com/tiagolpadua/zzlink_web#readme",
  "description": "Gerador de links wa.me para WhatsApp com QR Code",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "index.html": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcodejs": "^1.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-unicorn": "^68.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@alpinejs/focus": "^3.15.12",
    "alpinejs": "^3.15.12",
    "qrcode": "^1.5.4"
  }
}
